{
  "mcpServers": {

    "alphavantage": {
      "command": "uvx",
      "args": ["marketdata-mcp-server"],
      "env": {
        "ALPHA_VANTAGE_API_KEY": "TU_API_KEY_AQUI"
      }
    },

    "coingecko": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.api.coingecko.com/sse"
      ]
    },

    "defillama": {
      "command": "npx",
      "args": ["@mcp-dockmaster/mcp-server-defillama"]
    },

    "etoro-mcp": {
      "command": "node",
      "args": ["C:\\Users\\TU_USUARIO\\Documents\\eToro-MCP\\dist\\index.js"],
      "env": {
        "ETORO_API_KEY": "TU_ETORO_API_KEY",
        "ETORO_USER_KEY": "TU_ETORO_USER_KEY",
        "ETORO_TRADING_MODE": "demo"
      }
    },

    "investment-calculators": {
      "command": "uv",
      "args": ["--directory", "C:\\Users\\TU_USUARIO\\Documents\\mcp_finance\\mcp-server", "run", "server.py"]
    }

  }
}
